@echo off
setlocal

REM Actualiza Nyou desde GitHub (origin/main)
cd /d "%~dp0"

echo [Nyou] Git pull...
git pull --rebase
if errorlevel 1 (
  echo [Nyou] No se pudo actualizar (revisa tu conexion o credenciales de Git).
  pause
  exit /b 1
)

echo [Nyou] npm install...
cd /d "%~dp0nyou"
call npm install

echo [Nyou] Listo. Ahora ejecuta INICIAR_Nyou_WINDOWS.bat
pause
endlocal
